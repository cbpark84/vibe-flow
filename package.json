{
  "name": "vibe-flow",
  "displayName": "Vibe Flow",
  "description": "AI-powered coding assistant for VSCode",
  "version": "0.1.0",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeflow.openChat",
        "title": "%command.openChat%"
      },
      {
        "command": "vibeflow.setApiKey",
        "title": "%command.setApiKey%"
      },
      {
        "command": "vibeflow.clearHistory",
        "title": "%command.clearHistory%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibeflow-sidebar",
          "title": "Vibe Flow",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "vibeflow-sidebar": [
        {
          "type": "webview",
          "id": "vibeflow.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Vibe Flow",
      "properties": {
        "vibeflow.context.claude.triggerPercent": {
          "type": "number",
          "default": 70,
          "minimum": 30,
          "maximum": 90,
          "description": "%config.context.claude.triggerPercent.description%"
        },
        "vibeflow.context.claude.targetPercent": {
          "type": "number",
          "default": 50,
          "minimum": 20,
          "maximum": 80,
          "description": "%config.context.claude.targetPercent.description%"
        },
        "vibeflow.context.openai.triggerPercent": {
          "type": "number",
          "default": 65,
          "minimum": 30,
          "maximum": 90,
          "description": "%config.context.openai.triggerPercent.description%"
        },
        "vibeflow.context.openai.targetPercent": {
          "type": "number",
          "default": 45,
          "minimum": 20,
          "maximum": 80,
          "description": "%config.context.openai.targetPercent.description%"
        },
        "vibeflow.context.gemini.triggerPercent": {
          "type": "number",
          "default": 75,
          "minimum": 30,
          "maximum": 90,
          "description": "%config.context.gemini.triggerPercent.description%"
        },
        "vibeflow.context.gemini.targetPercent": {
          "type": "number",
          "default": 55,
          "minimum": 20,
          "maximum": 80,
          "description": "%config.context.gemini.targetPercent.description%"
        },
        "vibeflow.context.ollama.triggerPercent": {
          "type": "number",
          "default": 50,
          "minimum": 20,
          "maximum": 80,
          "description": "%config.context.ollama.triggerPercent.description%"
        },
        "vibeflow.context.ollama.targetPercent": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "maximum": 70,
          "description": "%config.context.ollama.targetPercent.description%"
        },
        "vibeflow.defaultProvider": {
          "type": "string",
          "enum": [
            "claude",
            "openai",
            "gemini",
            "ollama"
          ],
          "default": "claude",
          "description": "%config.defaultProvider.description%"
        },
        "vibeflow.systemPrompt": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "%config.systemPrompt.description%"
        },
        "vibeflow.maxTokensPerRequest": {
          "type": "number",
          "default": 4096,
          "minimum": 1024,
          "maximum": 32768,
          "description": "%config.maxTokensPerRequest.description%"
        }
      }
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@google/generative-ai": "^0.21.0",
    "diff": "^5.2.0",
    "openai": "^4.67.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  },
  "scripts": {
    "compile:ext": "node esbuild.config.js",
    "compile:web": "vite build",
    "compile": "npm run compile:ext && npm run compile:web",
    "watch:ext": "node esbuild.config.js --watch",
    "watch:web": "vite build --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src/**/*.{ts,tsx,css}",
    "package": "vsce package",
    "test": "NODE_PATH=./src/test/__mocks__:./node_modules npx ts-node --project tsconfig.test.json --transpile-only src/test/terminal.test.ts && NODE_PATH=./src/test/__mocks__:./node_modules npx ts-node --project tsconfig.test.json --transpile-only src/test/filesystem.test.ts && NODE_PATH=./src/test/__mocks__:./node_modules npx ts-node --project tsconfig.test.json --transpile-only src/test/errorHandler.test.ts && NODE_PATH=./src/test/__mocks__:./node_modules npx ts-node --project tsconfig.test.json --transpile-only src/test/factory.test.ts"
  }
}
