{
  "name": "vibe-flow",
  "displayName": "Vibe Flow",
  "description": "AI-powered coding assistant for VSCode",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeflow.openChat",
        "title": "Vibe Flow: Open Chat"
      },
      {
        "command": "vibeflow.setApiKey",
        "title": "Vibe Flow: Set API Key"
      },
      {
        "command": "vibeflow.clearHistory",
        "title": "Vibe Flow: Clear History"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibeflow-sidebar",
          "title": "Vibe Flow",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "configuration": {
      "title": "Vibe Flow",
      "properties": {
        "vibeflow.context.claude.triggerPercent": {
          "type": "number",
          "default": 70,
          "minimum": 30,
          "maximum": 90,
          "description": "Claude: 컨텍스트 트림을 시작하는 임계값 (%). 이 값을 초과하면 오래된 대화가 제거됩니다."
        },
        "vibeflow.context.claude.targetPercent": {
          "type": "number",
          "default": 50,
          "minimum": 20,
          "maximum": 80,
          "description": "Claude: 트림 후 목표 컨텍스트 사용률 (%). triggerPercent보다 낮아야 합니다."
        },
        "vibeflow.context.openai.triggerPercent": {
          "type": "number",
          "default": 65,
          "minimum": 30,
          "maximum": 90,
          "description": "OpenAI: 컨텍스트 트림을 시작하는 임계값 (%)."
        },
        "vibeflow.context.openai.targetPercent": {
          "type": "number",
          "default": 45,
          "minimum": 20,
          "maximum": 80,
          "description": "OpenAI: 트림 후 목표 컨텍스트 사용률 (%)."
        },
        "vibeflow.context.gemini.triggerPercent": {
          "type": "number",
          "default": 75,
          "minimum": 30,
          "maximum": 90,
          "description": "Gemini: 컨텍스트 트림을 시작하는 임계값 (%)."
        },
        "vibeflow.context.gemini.targetPercent": {
          "type": "number",
          "default": 55,
          "minimum": 20,
          "maximum": 80,
          "description": "Gemini: 트림 후 목표 컨텍스트 사용률 (%)."
        },
        "vibeflow.context.ollama.triggerPercent": {
          "type": "number",
          "default": 50,
          "minimum": 20,
          "maximum": 80,
          "description": "Ollama: 컨텍스트 트림을 시작하는 임계값 (%). 소용량 모델이므로 기본값이 낮습니다."
        },
        "vibeflow.context.ollama.targetPercent": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "maximum": 70,
          "description": "Ollama: 트림 후 목표 컨텍스트 사용률 (%)."
        },
        "vibeflow.defaultProvider": {
          "type": "string",
          "enum": ["claude", "openai", "gemini", "ollama"],
          "default": "claude",
          "description": "이 워크스페이스의 기본 AI 프로바이더"
        },
        "vibeflow.systemPrompt": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "이 워크스페이스의 커스텀 시스템 프롬프트 (비어 있으면 기본 프롬프트 사용)"
        },
        "vibeflow.maxTokensPerRequest": {
          "type": "number",
          "default": 4096,
          "minimum": 1024,
          "maximum": 32768,
          "description": "AI 요청당 최대 응답 토큰 수"
        }
      }
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@google/generative-ai": "^0.21.0",
    "diff": "^5.2.0",
    "openai": "^4.67.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  },
  "scripts": {
    "compile:ext": "node esbuild.config.js",
    "compile:web": "vite build",
    "compile": "npm run compile:ext && npm run compile:web",
    "watch:ext": "node esbuild.config.js --watch",
    "watch:web": "vite build --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src/**/*.{ts,tsx,css}",
    "package": "vsce package"
  }
}
